# ======================================
# Database Connection — 43 แฟ้ม Dashboard
# ======================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าให้ตรงกับระบบของคุณ
# Copy this file to .env and fill in your actual values

DB_HOST=your-db-host         # เช่น 192.168.1.100
DB_PORT=3306                 # port MySQL (default: 3306)
DB_USER=your-db-username     # เช่น root
DB_PASS=your-db-password     # รหัสผ่านฐานข้อมูล
DB_NAME=your-db-name         # เช่น datacenter

# ======================================
# Custom Report Security
# ======================================
CUSTOM_REPORT_ADMIN_PASS=your-admin-password
CUSTOM_REPORT_RUN_PASS=your-run-password
CUSTOM_REPORT_ALLOWED_TABLES=reimbursement,c_hos,person,home,service,diagnosis_opd,drug_opd,epi,labfu,anc,chronic,labor,custom_report
